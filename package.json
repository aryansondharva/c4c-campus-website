{
  "name": "c4c-campus-website",
  "type": "module",
  "version": "1.0.0",
  "description": "C4C Campus - AI Development Accelerator for Animal Liberation",
  "scripts": {
    "prepare": "husky || true",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "build:production": "npm run optimize:images && npm run check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "optimize:images": "node scripts/optimize-images.js",
    "analyze:bundle": "astro build --verbose",
    "perf:audit": "lighthouse http://localhost:4321 --output=html --output-path=./docs/performance/lighthouse-report.html",
    "db:types": "npx supabase gen types typescript --local > src/types/generated.ts",
    "db:types:check": "node scripts/check-schema-types.js",
    "db:types:check:full": "node scripts/check-schema-types.js --with-field-scan",
    "db:field-names:check": "node scripts/scan-field-names.js",
    "db:case:check": "node scripts/detect-case-mismatches.js",
    "db:validate": "node scripts/validate-schema.js",
    "db:validate:all": "npm run db:types:check && npm run db:field-names:check && npm run db:case:check",
    "db:reset": "echo '⚠️ DESTRUCTIVE: Deletes ALL data. Backup first: npm run db:backup' && echo 'Press Ctrl+C to cancel (5s countdown)...' && sleep 5 && psql $DATABASE_URL < schema.sql",
    "db:backup": "pg_dump $DATABASE_URL > backup_$(date +%Y%m%d_%H%M%S).sql",
    "db:schema-apply": "npm run db:backup && npm run db:reset && npm run db:validate"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.4",
    "@astrojs/react": "^5.0.1",
    "@astrojs/vercel": "^10.0.2",
    "@floating-ui/dom": "^1.7.5",
    "@stripe/stripe-js": "^8.8.0",
    "@supabase/storage-js": "^2.100.0",
    "@supabase/supabase-js": "^2.101.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-link": "^3.14.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.20.3",
    "@types/canvas-confetti": "^1.9.0",
    "@types/d3": "^7.4.3",
    "@types/papaparse": "^5.5.2",
    "@types/react-grid-layout": "^1.3.5",
    "astro": "^6.1.2",
    "canvas-confetti": "^1.9.4",
    "chart.js": "^4.5.1",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.1",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "handlebars": "^4.7.8",
    "html2canvas": "^1.4.1",
    "jose": "^6.2.2",
    "jspdf": "^4.2.1",
    "marked": "^17.0.3",
    "node-schedule": "^2.1.1",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "plyr": "^3.8.4",
    "qrcode": "^1.5.4",
    "react": "^19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.3",
    "resend": "^6.9.3",
    "sanitize-html": "^2.17.2",
    "sharp": "^0.34.4",
    "stripe": "^20.4.0",
    "tailwindcss": "^4.2.1",
    "ua-parser-js": "^2.0.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@axe-core/cli": "^4.11.0",
    "@axe-core/puppeteer": "^4.11.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^5.1.4",
    "axe-core": "^4.11.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "pg": "^8.20.0",
    "puppeteer": "^24.40.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "npm@10.8.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "path-to-regexp": "6.3.0",
    "lodash": "4.17.23",
    "tar": "7.5.9"
  }
}
